# Cloud Receiver - Environment Variables Example
# Copy this file to .env and adjust the values for your local or production environment.

# Listen Address Override
# CLOUD_BIND_ADDR=0.0.0.0:9000
# PROJECT_ROOT=/opt/src/AI-Agriculture
# CLOUD_CONFIG_PATH=/opt/src/AI-Agriculture/cloud/config/sensors.toml
# CLOUD_MIGRATION_DIR=/opt/src/AI-Agriculture/cloud/sql/migrations

# Database Configuration (Overrides config/sensors.toml)
# DATABASE_URL=postgres://postgres:CHANGE_ME@db:5432/ai_agriculture

# AI Service Endpoints (Overrides config/sensors.toml)
# AI_PREDICT_URL=http://ai-engine:8000/api/v1/predict
# AI_ENGINE_URL=http://127.0.0.1:8000
# OPENCLAW_URL=http://openclaw:3000

# Static File Roots
# STATIC_SOURCE_FRONTEND=/opt/src/AI-Agriculture/frontend
# STATIC_SOURCE_DASHBOARD=/opt/src/AI-Agriculture/cloud/dashboard
# STATIC_TARGET_FRONTEND=/opt/ai-agriculture/frontend
# STATIC_TARGET_DASHBOARD=/opt/ai-agriculture/cloud/dashboard

# Deployment Script Overrides
# INSTALL_ROOT=/opt/ai-agriculture/cloud
# BIN_NAME=ai-agri-cloud-receiver
# LOG_DIR=/opt/src/AI-Agriculture/cloud/logs
# START_AI_ENGINE=1
# AI_BIND_ADDR=0.0.0.0:8000
# AI_HEALTH_URL=http://127.0.0.1:8000/api/v1/health
# CLOUD_HEALTH_URL=http://127.0.0.1:9000/api/v1/plantations
# CROP_PROFILE=oil_palm
# SERVICE_NAME=ai-agri-cloud-receiver
# STOP_SYSTEMD=0
# FORCE_KILL_PORT=0

# Local State Storage Overrides
# TOKEN_STORE_PATH=state/token_store.json
# REGISTRY_PATH=state/registry.json
# TELEMETRY_STORE_PATH=state/telemetry.jsonl
# IMAGE_STORE_PATH=state/image_uploads
# IMAGE_INDEX_PATH=state/image_index.jsonl
# IMAGE_DB_ERROR_STORE_PATH=state/image_upload_errors.jsonl
