# Gateway runtime environment example
# Copy to `.env` and source it before running (or set variables in systemd).

# Core target/state defaults
# GATEWAY_DEFAULT_TARGET=YOUR_CLOUD_IP:9000
# GATEWAY_CLOUD_TARGET=YOUR_CLOUD_IP:9000
# GATEWAY_STATE_DIR=state
# GATEWAY_BAUD_LIST=115200,57600,9600,74880

# Image upload derivation (used when --image-upload-url is not provided)
# GATEWAY_IMAGE_UPLOAD_SCHEME=http
# GATEWAY_IMAGE_UPLOAD_PORT=8088
# GATEWAY_IMAGE_UPLOAD_PATH=/api/v1/image/upload
# GATEWAY_IMAGE_DIR=sample_images
# GATEWAY_IMAGE_UPLOAD_INTERVAL_MS=300000

# Modbus profile overrides
# GATEWAY_MODBUS_PORT=/dev/ttyUSB0
# GATEWAY_MODBUS_SLAVE_ID=2
# GATEWAY_MODBUS_FUNCTION_CODE=3
# GATEWAY_MODBUS_START_ADDR=0
# GATEWAY_MODBUS_REG_COUNT=3
# GATEWAY_MODBUS_RESPONSE_LEN=11
# GATEWAY_MODBUS_EXPECTED_BYTE_COUNT=6
# GATEWAY_MODBUS_SENSOR_ID=soil_modbus_02
# GATEWAY_MODBUS_FEATURE=soil_modbus
# GATEWAY_MODBUS_PROTOCOL=modbus.rtu.v1
# GATEWAY_MODBUS_POLL_INTERVAL_MS=1000
# GATEWAY_MODBUS_REQUEST_GAP_MS=80
# GATEWAY_MODBUS_RESPONSE_TIMEOUT_MS=900
# GATEWAY_MODBUS_DISCOVERY_RESPONSE_TIMEOUT_MS=650
